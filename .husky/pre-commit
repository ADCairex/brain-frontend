#!/bin/sh

# Get list of staged JS/JSX files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Format staged files (modifies but does NOT stage - user reviews changes)
echo "$STAGED_FILES" | xargs npx prettier --write

# Check if prettier made any changes
if ! git diff --quiet $STAGED_FILES; then
  echo ""
  echo "Prettier formatted some files. Review the changes:"
  echo ""
  git diff --stat $STAGED_FILES
  echo ""
  echo "Run 'git diff' to see details, then 'git add' and commit again."
  exit 1
fi

# Run ESLint (fail on errors, no auto-fix)
echo "$STAGED_FILES" | xargs npx eslint

{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@finance/*": ["./src/modules/finance/*"],
      "@calendar/*": ["./src/modules/calendar/*"],
      "@shared/*": ["./src/shared/*"],
      "@shell/*": ["./src/shell/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/modules/**/*.{js,jsx}",
    "src/shell/**/*.{js,jsx}",
    "src/shared/context/**/*.{js,jsx}",
    "src/shared/hooks/**/*.{js,jsx}",
    "src/shared/lib/**/*.{js,jsx}",
    "src/main.jsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/vite-plugins",
    "src/shared/components/ui/**"
  ]
}
